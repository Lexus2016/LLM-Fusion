#!/usr/bin/env bash
# fusion-opencode — launch OpenCode wired to the llm-fusion Fusion Proxy with a chosen model.
#
# Usage:
#   fusion-opencode [model] [opencode args...]   # default model: fusion-agents
#   fusion-opencode                              # interactive TUI, smart agent routing
#   fusion-opencode fusion-coder                 # interactive TUI, full coding panel
#   fusion-opencode fusion-agents run "Fix bug X"  # headless one-shot
#
# What it does:
#   1. starts the proxy (npm start) if it is not already answering on /health;
#   2. ensures the `fusion` provider exists in your global OpenCode config
#      (idempotent merge — only the `fusion` key is written, everything else is kept;
#      an existing config is backed up to opencode.json.bak-<UTC ts> first, a malformed
#      one aborts instead of being overwritten, and the file is chmod 0600);
#   3. launches OpenCode with `-m fusion/<model>`.
#
# Env:
#   FUSION_PROXY_URL    override proxy URL (default http://127.0.0.1:8080)
#   FUSION_PROXY_TOKEN  if your proxy requires a client token, it is used as the apiKey
set -euo pipefail

# The first positional arg selects the model, but ONLY when it is not a flag.
# Otherwise `fusion-opencode --some-flag` would swallow `--some-flag` as the
# model name and drop the flag; a leading `-...` means "no model given — use
# the default and pass every arg straight through to opencode".
MODEL="fusion-agents"
if [ "$#" -gt 0 ] && [[ "$1" != -* ]]; then
  MODEL="$1"
  shift
fi

# Resolve the script's real location even when invoked through a symlink
# (e.g. ~/.local/bin/fusion-opencode -> .../llm-fusion/bin/fusion-opencode) —
# BASH_SOURCE alone points at the symlink, not the target, and dirname on
# that yields the wrong REPO.
SOURCE="${BASH_SOURCE[0]}"
while [ -L "$SOURCE" ]; do
  DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"
  SOURCE="$(readlink "$SOURCE")"
  [[ "$SOURCE" != /* ]] && SOURCE="$DIR/$SOURCE"
done
REPO="$(cd -P "$(dirname "$SOURCE")/.." && pwd)"
PROXY_URL="${FUSION_PROXY_URL:-http://127.0.0.1:8080}"

# 1. ensure the proxy is up ---------------------------------------------------
if ! curl -fsS "$PROXY_URL/health" >/dev/null 2>&1; then
  echo "[fusion-opencode] proxy not up — starting it from $REPO ..." >&2
  ( cd "$REPO" && nohup npm start >"${TMPDIR:-/tmp}/llm-fusion-proxy.log" 2>&1 & )
  for _ in $(seq 1 60); do
    curl -fsS "$PROXY_URL/health" >/dev/null 2>&1 && break
    sleep 0.5
  done
  if ! curl -fsS "$PROXY_URL/health" >/dev/null 2>&1; then
    echo "[fusion-opencode] proxy failed to start — see ${TMPDIR:-/tmp}/llm-fusion-proxy.log" >&2
    exit 1
  fi
  echo "[fusion-opencode] proxy is up at $PROXY_URL" >&2
fi

# 2. ensure the fusion provider is in the global OpenCode config (idempotent) --
OC_CFG="${XDG_CONFIG_HOME:-$HOME/.config}/opencode/opencode.json"
mkdir -p "$(dirname "$OC_CFG")"
FUSION_PROXY_URL="$PROXY_URL" python3 - "$OC_CFG" <<'PY'
import datetime, json, os, shutil, sys
path = sys.argv[1]
proxy = os.environ.get("FUSION_PROXY_URL", "http://127.0.0.1:8080")
# Write apiKey only from a real source: FUSION_PROXY_TOKEN when set, else the
# key already stored in the file, else the harmless "local-no-auth" placeholder
# (the unauthenticated proxy accepts any non-empty key, and OpenCode's
# openai-compatible provider expects SOME apiKey to be present).
# Unconditionally rewriting it meant: run once WITH FUSION_PROXY_TOKEN, later
# without -> the stored token was silently overwritten and OpenCode started 401ing.
api_key = os.environ.get("FUSION_PROXY_TOKEN")
cfg = {}
existed = os.path.exists(path)
if existed:
    try:
        with open(path) as f:
            cfg = json.load(f)
    except Exception as err:
        # NEVER fall back to {} here: writing that back would silently wipe the
        # user's other providers/agents/keybinds. Abort and touch nothing.
        print(
            f"[fusion-opencode] ERROR: {path} exists but is not valid JSON ({err}).\n"
            f"[fusion-opencode] refusing to overwrite it — fix or remove the file manually, then re-run.",
            file=sys.stderr,
        )
        sys.exit(1)
cfg.setdefault("$schema", "https://opencode.ai/config.json")
fusion = {
    "npm": "@ai-sdk/openai-compatible",
    "name": "Fusion Proxy",
    "options": {"baseURL": proxy.rstrip("/") + "/v1"},
    "models": {
        "fusion-coder": {"name": "Fusion Coder"},
        "fusion-researcher": {"name": "Fusion Researcher"},
        "fusion-agents": {"name": "Fusion Agents"},
        "fusion-1": {"name": "Fusion 1"},
        "smart-1": {"name": "Smart 1"},
        "fast-glm": {"name": "Fast GLM"},
    },
}
prev_fusion = cfg.get("provider", {}).get("fusion", {})
prev_key = prev_fusion.get("options", {}).get("apiKey") if isinstance(prev_fusion, dict) else None
if api_key:
    fusion["options"]["apiKey"] = api_key
elif isinstance(prev_key, str) and prev_key:
    fusion["options"]["apiKey"] = prev_key
else:
    fusion["options"]["apiKey"] = "local-no-auth"
cfg.setdefault("provider", {})["fusion"] = fusion
# Back up an existing config before overwriting it (it is the user's file,
# not ours — a bad write must never be unrecoverable).
if existed:
    stamp = datetime.datetime.now(datetime.timezone.utc).strftime("%Y%m%dT%H%M%SZ")
    shutil.copy2(path, f"{path}.bak-{stamp}")
with open(path, "w") as f:
    json.dump(cfg, f, indent=2)
# The file carries the client token — 0600 like fusion-claude's settings file.
os.chmod(path, 0o600)
print(f"[fusion-opencode] ensured `fusion` provider in {path}", file=sys.stderr)
PY

# 3. launch OpenCode with the chosen model ------------------------------------
echo "[fusion-opencode] launching: opencode -m fusion/${MODEL} $*" >&2
exec opencode -m "fusion/${MODEL}" "$@"
